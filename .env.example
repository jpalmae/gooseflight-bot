# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
AUTHORIZED_USER_ID=

# ── Goose ─────────────────────────────────────────────
GOOSE_PROVIDER=avian
GOOSE_MODEL=glm-5.1
GOOSE_BIN=
AVIAN_API_KEY=
AVIAN_HOST=https://api.z.ai/api/coding/paas/v4

# ── Whisper (voz) ────────────────────────────────────
WHISPER_BACKEND=openai          # openai | local
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
WHISPER_LOCAL_MODEL=small
WHISPER_LANGUAGE=es

# ── Paths ─────────────────────────────────────────────
DATA_DIR=./data
SQLITE_PATH=
WORKSPACE_DIR=/workspace

# ── Behaviour ─────────────────────────────────────────
STREAM_EDIT_INTERVAL_SECONDS=1.5
COMPLETION_NOTIF_THRESHOLD_SECONDS=30
TOOL_APPROVAL_TIMEOUT_SECONDS=600
MAX_FILE_SIZE_BYTES=52428800

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console               # json | console
TZ=America/Santiago
